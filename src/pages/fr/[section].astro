---
import InteriorPage from "../../components/InteriorPage.astro";
import Documentation from "../../components/Documentation.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { pages, type Section } from "../../data/pages";
import { docs } from "../../data/docs";
import { artifacts } from "../../data/releases";
import { highlightCode } from "../../lib/highlight";
import { site } from "../../data/site";

export function getStaticPaths() {
  return (["learn", "architecture", "journal", "download"] as const).map((section) => ({ params: { section }, props: { section } }));
}

const { section } = Astro.props as { section: Section };
const page = pages.fr[section];
const documentation = docs.fr[section];
const helloCode = `fonction principal() {
  afficher("Bonjour, monde!")
}`;
const architectureCode = `lumiere programme.lum
lumiere
lumiere tester tests`;
const journalCode = `version actuelle
guide du langage
ligne de commande
compilation des sources
notes de version`;
const buildCode = `git clone ${site.repository}
cd lumiere
cmake -S . -B build -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTING=ON
cmake --build build --parallel 2
ctest --test-dir build --output-on-failure
sudo cmake --install build
lumiere --version`;
---
<SiteLayout locale="fr" title={`${page.eyebrow} — Lumière`} description={page.intro}>
  <InteriorPage locale="fr" section={section} {...page}>
    {section === "learn" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>bonjour.lum</span><span>premier programme</span></div>
            <pre><code set:html={highlightCode(helloCode)} /></pre>
          </div>
        </div>
        <div class="index">
          <a href="#installation-outils"><span>Outils</span><strong>Préparer les outils</strong><p>Installez VS Code, ajoutez l’extension Lumière, créez un fichier <code>.lum</code> et vérifiez la ligne de commande.</p></a>
          <a href="#premier-programme"><span>Premier fichier</span><strong>Lancer un premier programme</strong><p>Écrivez <code>bonjour.lum</code>, enregistrez-le, lancez-le et comprenez chaque ligne.</p></a>
          <a href="#valeurs"><span>Concepts</span><strong>Apprendre les idées de base</strong><p>Avancez des valeurs vers variables, calculs, fonctions, valeurs retournées, contrôle de flux, boucles, types, modules et tests.</p></a>
        </div>
      </>
    )}

    {section === "architecture" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>version {site.version}</span><span>carte d’architecture</span></div>
            <pre><code set:html={highlightCode(architectureCode)} /></pre>
          </div>
        </div>
        <div class="index">
          <a href="#langage"><span>01</span><strong>Surface du langage</strong><p>La surface documentée couvre déclarations, valeurs typées, modules, objets, collections et contrôle de flux.</p></a>
          <a href="#executer"><span>02</span><strong>Ligne de commande</strong><p>Utilisez la ligne de commande pour lancer des fichiers, ouvrir le shell, tester des projets et inspecter les programmes si nécessaire.</p></a>
          <a href="#frontieres"><span>03</span><strong>Bibliothèque standard et outils</strong><p>Les modules intégrés incluent <code>Maths</code>, <code>Fichier</code>, <code>Chemin</code>, <code>Texte</code>, <code>Temps</code> et <code>Aléatoire</code> ; l’outillage inclut <code>LumiTest</code>.</p></a>
        </div>
      </>
    )}

    {section === "journal" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>journal</span><span>notes du projet</span></div>
            <pre><code set:html={highlightCode(journalCode)} /></pre>
          </div>
        </div>
        <div class="journal-list">
          <div class="empty-state">
            <span>Aucun article publié pour le moment</span>
            <strong>Le journal apparaîtra ici lorsque le premier article sera écrit.</strong>
            <p>D’ici là, utilisez les pages Apprendre, Architecture et Télécharger pour la documentation publique actuelle.</p>
          </div>
        </div>
      </>
    )}

    {section === "download" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>compiler les sources</span><span>compiler, tester, installer</span></div>
            <pre><code set:html={highlightCode(buildCode)} /></pre>
          </div>
        </div>
        <div class="release-table">
          {artifacts.map((artifact) => (
            <a href={artifact.href}>
              <span>{artifact.format}</span>
              <strong>{artifact.label}</strong>
              <small>{artifact.detail}</small>
              <i>Télécharger</i>
            </a>
          ))}
          <a href={site.repository}>
            <span>source</span>
            <strong>Compiler avec CMake</strong>
            <small>Utilisez cette voie quand aucun artefact ne correspond à votre processeur ou système.</small>
            <i>GitHub</i>
          </a>
        </div>
      </>
    )}

    {documentation && <Documentation content={documentation} locale="fr" />}
  </InteriorPage>
</SiteLayout>
