---
import InteriorPage from "../../components/InteriorPage.astro";
import Documentation from "../../components/Documentation.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { pages, type Section } from "../../data/pages";
import { docs } from "../../data/docs";
import { artifacts } from "../../data/releases";
import { highlightCode } from "../../lib/highlight";
import { formatInlineCode } from "../../lib/inline-code";
import { site } from "../../data/site";

export function getStaticPaths() {
  return (["learn", "examples", "architecture", "journal", "download"] as const).map((section) => ({ params: { section }, props: { section } }));
}

const { section } = Astro.props as { section: Section };
const page = pages.fr[section];
const documentation = docs.fr[section];
const learnSections = docs.fr.learn!.sections;
const helloCode = `fonction principal() {
  afficher("Bonjour, monde!")
}`;
const architectureCode = `source
  -> tokens
  -> AST
  -> valeurs runtime
  -> tree-walk ou VM
  -> diagnostics`;
const journalCode = `version actuelle
guide du langage
ligne de commande
compilation des sources
notes de version`;
const buildCode = `git clone ${site.repository}
cd lumiere
cmake -S . -B build -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTING=ON
cmake --build build --parallel 2
ctest --test-dir build --output-on-failure
sudo cmake --install build
lumiere --version`;
---
<SiteLayout locale="fr" title={`${page.eyebrow} — Lumière`} description={page.intro}>
  <InteriorPage locale="fr" section={section} {...page}>
    {section === "learn" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>bonjour.lum</span><span>premier programme</span></div>
            <pre><code set:html={highlightCode(helloCode)} /></pre>
          </div>
        </div>
        <nav class="doc-index" aria-label="Index de la documentation d’apprentissage">
          <div class="doc-index-head">
            <span>Index de documentation</span>
            <a href="/fr/learn/tutorial/#installation-outils">Ouvrir le tutoriel</a>
          </div>
          <div class="doc-index-list">
            {learnSections.map((tutorialSection, index) => (
              <a href={`/fr/learn/tutorial/#${tutorialSection.id}`}>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong>{tutorialSection.title}</strong>
                <p set:html={formatInlineCode(tutorialSection.body[0] ?? "")} />
              </a>
            ))}
          </div>
        </nav>
      </>
    )}

    {section === "architecture" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>version {site.version}</span><span>carte d’architecture</span></div>
            <pre><code set:html={highlightCode(architectureCode)} /></pre>
          </div>
        </div>
        <div class="index">
          <a href="#source-francais"><span>01</span><strong>Source français</strong><p>Comment Lumière accepte identifiants accentués, mots-clés français, symboles Unicode et alias ASCII.</p></a>
          <a href="#pipeline-execution"><span>02</span><strong>Pipeline d’exécution</strong><p>Comment le source passe par tokenisation, parsing, diagnostics, exécution tree-walk et lowering VM.</p></a>
          <a href="#luminet-module"><span>03</span><strong>LumiNet</strong><p>Comment le réseau est construit avec objets de capacités, état natif, sockets, routes HTTP et callbacks Canal.</p></a>
        </div>
      </>
    )}

    {section === "journal" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>journal</span><span>notes du projet</span></div>
            <pre><code set:html={highlightCode(journalCode)} /></pre>
          </div>
        </div>
        <div class="journal-list">
          <div class="empty-state">
            <span>Aucun article publié pour le moment</span>
            <strong>Le journal apparaîtra ici lorsque le premier article sera écrit.</strong>
            <p>D’ici là, utilisez les pages Apprendre, Architecture et Télécharger pour la documentation publique actuelle.</p>
          </div>
        </div>
      </>
    )}

    {section === "download" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>compiler les sources</span><span>compiler, tester, installer</span></div>
            <pre><code set:html={highlightCode(buildCode)} /></pre>
          </div>
        </div>
        <div class="release-table">
          {artifacts.map((artifact) => (
            <a href={artifact.href}>
              <span>{artifact.format}</span>
              <strong>{artifact.label}</strong>
              <small>{artifact.detail}</small>
              <i>Télécharger</i>
            </a>
          ))}
          <a href={site.repository}>
            <span>source</span>
            <strong>Compiler avec CMake</strong>
            <small>Utilisez cette voie quand aucun artefact ne correspond à votre processeur ou système.</small>
            <i>GitHub</i>
          </a>
        </div>
      </>
    )}

    {documentation && section !== "learn" && <Documentation content={documentation} locale="fr" />}
  </InteriorPage>
</SiteLayout>
