---
import InteriorPage from "../../components/InteriorPage.astro";
import Documentation from "../../components/Documentation.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { pages, type Section } from "../../data/pages";
import { docs } from "../../data/docs";
import { artifacts } from "../../data/releases";
import { highlightCode } from "../../lib/highlight";
import { site } from "../../data/site";

export function getStaticPaths() {
  return (["learn", "architecture", "journal", "download"] as const).map((section) => ({ params: { section }, props: { section } }));
}

const { section } = Astro.props as { section: Section };
const page = pages.en[section];
const documentation = docs.en[section];
const helloCode = `fonction principal() {
  afficher("Bonjour, monde!")
}`;
const architectureCode = `lumiere programme.lum
lumiere
lumiere tester tests`;
const journalCode = `current release
language guide
command line
source builds
release notes`;
const buildCode = `git clone ${site.repository}
cd lumiere
cmake -S . -B build -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTING=ON
cmake --build build --parallel 2
ctest --test-dir build --output-on-failure
sudo cmake --install build
lumiere --version`;
---
<SiteLayout locale="en" title={`${page.eyebrow} — Lumière`} description={page.intro}>
  <InteriorPage locale="en" section={section} {...page}>
    {section === "learn" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>bonjour.lum</span><span>first program</span></div>
            <pre><code set:html={highlightCode(helloCode)} /></pre>
          </div>
        </div>
        <div class="index">
          <a href="#setup"><span>Setup</span><strong>Set up the tools</strong><p>Install VS Code, add the Lumière extension, create a <code>.lum</code> file, and check the command line.</p></a>
          <a href="#first-program"><span>First file</span><strong>Run a first program</strong><p>Write <code>bonjour.lum</code>, save it, run it, and understand what each line does.</p></a>
          <a href="#values"><span>Concepts</span><strong>Learn the core ideas</strong><p>Build from values to variables, calculations, functions, return values, control flow, loops, types, modules, and tests.</p></a>
        </div>
      </>
    )}

    {section === "architecture" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>release {site.version}</span><span>architecture map</span></div>
            <pre><code set:html={highlightCode(architectureCode)} /></pre>
          </div>
        </div>
        <div class="index">
          <a href="#language"><span>01</span><strong>Language surface</strong><p>The documented surface covers declarations, typed values, modules, objects, collections, and control flow.</p></a>
          <a href="#running-programs"><span>02</span><strong>Command line</strong><p>Use the command line to run files, open the shell, test projects, and inspect programs when needed.</p></a>
          <a href="#project-boundaries"><span>03</span><strong>Standard library and tools</strong><p>Built-in modules include <code>Maths</code>, <code>Fichier</code>, <code>Chemin</code>, <code>Texte</code>, <code>Temps</code>, and <code>Aléatoire</code>; project tooling includes <code>LumiTest</code>.</p></a>
        </div>
      </>
    )}

    {section === "journal" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>journal</span><span>project notes</span></div>
            <pre><code set:html={highlightCode(journalCode)} /></pre>
          </div>
        </div>
        <div class="journal-list">
          <div class="empty-state">
            <span>No published articles yet</span>
            <strong>The journal will appear here once the first article is written.</strong>
            <p>Until then, use the Learn, Architecture, and Download pages for the current public documentation.</p>
          </div>
        </div>
      </>
    )}

    {section === "download" && (
      <>
        <div class="lead">
          <div>
            <h2>{page.heading}</h2>
            <p class="lede">{page.body}</p>
          </div>
          <div class="panel code-panel">
            <div class="panel-head"><span>build from source</span><span>build, test, install</span></div>
            <pre><code set:html={highlightCode(buildCode)} /></pre>
          </div>
        </div>
        <div class="release-table">
          {artifacts.map((artifact) => (
            <a href={artifact.href}>
              <span>{artifact.format}</span>
              <strong>{artifact.label}</strong>
              <small>{artifact.detail}</small>
              <i>Download</i>
            </a>
          ))}
          <a href={site.repository}>
            <span>source</span>
            <strong>Build with CMake</strong>
            <small>Use this path when no release artifact matches your CPU or operating system.</small>
            <i>GitHub</i>
          </a>
        </div>
      </>
    )}

    {documentation && <Documentation content={documentation} locale="en" />}
  </InteriorPage>
</SiteLayout>
