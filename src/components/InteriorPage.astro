---
import type { Section } from "../data/pages";
import type { Locale } from "../data/site";
import { site } from "../data/site";

interface Props {
  locale: Locale;
  section: Section;
  eyebrow: string;
  title: string;
  intro: string;
}

const { locale, section, eyebrow, title, intro } = Astro.props;
const releaseLabel = locale === "fr" ? "Version actuelle" : "Current release";
const alphaLabel = locale === "fr" ? "Alpha publique" : "Public alpha";
---
<main class:list={["interior", section]}>
  <section class="shell">
    <div class="masthead">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{intro}</p>
    </div>

    <aside class="release" aria-label={releaseLabel}>
      <span>{alphaLabel}</span>
      <strong>{site.version}</strong>
      <a href={`/${locale}/download/`}>{releaseLabel}</a>
    </aside>

    <div class="content">
      <slot />
    </div>
  </section>
</main>

<style>
  .interior {
    min-height: calc(100svh - var(--header));
    padding: clamp(2rem, 4vw, 3rem) var(--gutter) clamp(5rem, 9vw, 7rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .025), transparent 22rem),
      #121719;
  }

  .shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 16rem;
    gap: clamp(3rem, 7vw, 6rem);
    width: min(100%, var(--page));
    margin: auto;
    padding: clamp(3rem, 7vw, 5.5rem) 0 0;
  }

  .masthead {
    max-width: 58rem;
  }

  .eyebrow {
    color: #8e9aa0;
  }

  h1 {
    max-width: 54rem;
    margin: 0;
    color: var(--ink);
    font: 500 clamp(3.2rem, 7vw, 5.8rem)/.98 var(--font-body);
    letter-spacing: -.055em;
  }

  .masthead > p:last-child {
    max-width: 45rem;
    margin: 1.8rem 0 0;
    color: #a9b3b8;
    font-size: 1.08rem;
  }

  .release {
    align-self: end;
    padding-top: 1rem;
    border-top: 1px solid #30383c;
  }

  .release span,
  .release a {
    display: block;
    color: #7e8a90;
    font: 500 .66rem var(--font-mono);
    letter-spacing: .1em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .release strong {
    display: block;
    margin: .8rem 0 1.35rem;
    color: var(--ink);
    font: 500 2.4rem/1 var(--font-body);
    letter-spacing: -.045em;
  }

  .release a {
    color: #d98270;
  }

  .content {
    grid-column: 1 / -1;
    margin-top: clamp(3rem, 6vw, 5rem);
    padding-top: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid #30383c;
  }

  .content :global(.lead) {
    display: grid;
    grid-template-columns: minmax(0, .9fr) minmax(20rem, 1.1fr);
    gap: clamp(3rem, 8vw, 7rem);
    align-items: start;
  }

  .content :global(h2) {
    max-width: 35rem;
    margin: 0;
    color: var(--ink);
    font: 500 clamp(2rem, 4vw, 3.15rem)/1.08 var(--font-body);
    letter-spacing: -.04em;
  }

  .content :global(p) {
    max-width: 46rem;
    margin: 0;
    color: #9fa9ae;
  }

  .content :global(.lede) {
    color: #bec6ca;
    font-size: 1.02rem;
  }

  .content :global(.panel) {
    border: 1px solid #30383c;
    background: #171d20;
  }

  .content :global(.code-panel) {
    overflow: hidden;
  }

  .content :global(.panel-head) {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: .85rem 1rem;
    border-bottom: 1px solid #30383c;
    color: #758187;
    font: .64rem var(--font-mono);
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .content :global(pre) {
    margin: 0;
    padding: clamp(1.25rem, 3vw, 2rem);
    overflow-x: auto;
    color: #dde3e5;
    font: .82rem/1.9 var(--font-mono);
  }

  .content :global(.index) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: clamp(3rem, 7vw, 5rem);
    background: #30383c;
    border: 1px solid #30383c;
  }

  .content :global(.index > *) {
    min-height: 11rem;
    padding: 1.25rem;
    background: #171d20;
    text-decoration: none;
  }

  .content :global(.index span),
  .content :global(.release-table span),
  .content :global(.journal-list span) {
    color: #758187;
    font: .64rem var(--font-mono);
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .content :global(.index strong),
  .content :global(.release-table strong),
  .content :global(.journal-list strong) {
    display: block;
    margin-top: .8rem;
    color: var(--ink);
    font-weight: 500;
  }

  .content :global(.index p) {
    margin-top: .75rem;
    font-size: .86rem;
  }

  .content :global(.release-table),
  .content :global(.journal-list) {
    margin-top: clamp(3rem, 7vw, 5rem);
    border-top: 1px solid #30383c;
  }

  .content :global(.release-table a),
  .content :global(.journal-list a) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: .4rem 2rem;
    min-height: 4rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid #30383c;
    text-decoration: none;
  }

  .content :global(.release-table small),
  .content :global(.journal-list small) {
    color: #8f9aa0;
    font-size: .78rem;
  }

  .content :global(.release-table i),
  .content :global(.journal-list i) {
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
    color: #d98270;
    font: normal .72rem var(--font-mono);
    text-transform: uppercase;
  }

  .content :global(.empty-state) {
    padding: clamp(1.5rem, 4vw, 2rem) 0;
    border-bottom: 1px solid #30383c;
  }

  .content :global(.empty-state span) {
    color: #758187;
    font: .64rem var(--font-mono);
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .content :global(.empty-state strong) {
    display: block;
    max-width: 42rem;
    margin-top: .85rem;
    color: var(--ink);
    font: 500 clamp(1.35rem, 3vw, 2rem)/1.15 var(--font-body);
    letter-spacing: -.03em;
  }

  .content :global(.empty-state p) {
    margin-top: .9rem;
    color: #9fa9ae;
    font-size: .9rem;
  }

  .content :global(.detail-block) {
    margin-top: clamp(3rem, 7vw, 5rem);
    padding-top: clamp(2rem, 5vw, 3rem);
    border-top: 1px solid #30383c;
  }

  .content :global(.detail-block h3) {
    max-width: 42rem;
    margin: 0;
    color: var(--ink);
    font: 500 clamp(1.6rem, 3vw, 2.35rem)/1.12 var(--font-body);
    letter-spacing: -.035em;
  }

  .content :global(.detail-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin-top: 1.75rem;
    background: #30383c;
    border: 1px solid #30383c;
  }

  .content :global(.detail-grid > div) {
    min-height: 9rem;
    padding: 1.15rem;
    background: #171d20;
  }

  .content :global(.detail-grid span) {
    display: block;
    color: #d98270;
    font: .64rem var(--font-mono);
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .content :global(.detail-grid p) {
    margin-top: .75rem;
    color: #a7b0b5;
    font-size: .86rem;
  }

  .content :global(.detail-grid code) {
    color: #dde3e5;
    font-family: var(--font-mono);
    font-size: .82em;
  }

  @media (max-width: 860px) {
    .shell,
    .content :global(.lead) {
      grid-template-columns: 1fr;
    }

    .release {
      max-width: 18rem;
    }

    .content :global(.index) {
      grid-template-columns: 1fr;
    }

    .content :global(.detail-grid) {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .interior {
      padding-top: 1rem;
      padding-bottom: 4rem;
    }

    .shell {
      gap: 2rem;
      padding-top: 1.75rem;
    }

    h1 {
      font-size: clamp(2.45rem, 13vw, 3.15rem);
      letter-spacing: -.05em;
    }

    .masthead > p:last-child {
      margin-top: 1.25rem;
      font-size: .98rem;
    }

    .release strong {
      font-size: 2rem;
    }

    .release a {
      display: inline-flex;
      align-items: center;
      min-height: 2.75rem;
    }

    .content {
      margin-top: 2rem;
      padding-top: 2rem;
    }

    .content :global(.lead) {
      gap: 2rem;
    }

    .content :global(pre) {
      padding: 1rem;
      font-size: .74rem;
      line-height: 1.75;
    }

    .content :global(.panel-head) {
      align-items: flex-start;
      flex-direction: column;
      gap: .35rem;
    }

    .content :global(.index > *) {
      display: block;
      min-height: auto;
      padding: 1rem;
    }

    .content :global(.index p) {
      font-size: .82rem;
    }

    .content :global(.detail-grid > div) {
      min-height: auto;
      padding: 1rem;
    }

    .content :global(.release-table a),
    .content :global(.journal-list a) {
      grid-template-columns: 1fr;
      gap: .5rem;
      padding: 1rem 0;
    }

    .content :global(.release-table i),
    .content :global(.journal-list i) {
      grid-column: auto;
      grid-row: auto;
    }
  }
</style>
