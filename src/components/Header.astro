---
import Brand from "./Brand.astro";
import { alternatePath, getCopy } from "../lib/i18n";
import { type Locale } from "../data/site";

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getCopy(locale);
const base = `/${locale}`;
---
<header>
  <a class="home" href={`${base}/`}><Brand /></a>
  <button class="menu-button" type="button" aria-expanded="false" aria-controls="primary-navigation">
    <span>{locale === "en" ? "Menu" : "Menu"}</span>
    <i aria-hidden="true"></i>
  </button>
  <nav id="primary-navigation" aria-label="Primary navigation">
    <a href={`${base}/learn/`}>{t.nav.learn}</a>
    <a href={`${base}/architecture/`}>{t.nav.architecture}</a>
    <a href={`${base}/journal/`}>{t.nav.journal}</a>
    <a href={`${base}/download/`}>{t.nav.download}</a>
    <a class="locale" href={alternatePath(Astro.url.pathname, locale)} hreflang={locale === "en" ? "fr" : "en"}>{locale === "en" ? "FR" : "EN"}</a>
  </nav>
</header>

<script>
  const header = document.querySelector("header");
  const button = header?.querySelector<HTMLButtonElement>(".menu-button");
  const nav = header?.querySelector<HTMLElement>("#primary-navigation");

  const setOpen = (open: boolean) => {
    header?.toggleAttribute("data-open", open);
    button?.setAttribute("aria-expanded", String(open));
  };

  button?.addEventListener("click", () => {
    setOpen(button.getAttribute("aria-expanded") !== "true");
  });

  nav?.addEventListener("click", (event) => {
    if (event.target instanceof HTMLAnchorElement) setOpen(false);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setOpen(false);
  });

  document.addEventListener("click", (event) => {
    if (!header?.contains(event.target as Node)) setOpen(false);
  });
</script>

<style>
  header { position: sticky; top: 0; z-index: 10; display: flex; align-items: center; justify-content: space-between; gap: 1rem; width: min(100% - 2 * var(--gutter), var(--page)); height: var(--header); margin: auto; border-bottom: 1px solid var(--line); background: rgba(23, 26, 28, .92); backdrop-filter: blur(18px); }
  a, button { color: inherit; }
  a { text-decoration: none; }
  button { font: inherit; }
  .home { flex: 0 0 auto; }
  nav { display: flex; align-items: center; justify-content: flex-end; min-width: 0; gap: clamp(.85rem, 2.5vw, 2.2rem); color: var(--muted); font-size: .78rem; }
  nav a { transition: color .15s; }
  nav a:hover { color: var(--ink); }
  .locale { padding-left: 1.2rem; border-left: 1px solid var(--line); font: .67rem var(--font-mono); }
  .menu-button { display: none; align-items: center; gap: .7rem; min-height: 2.9rem; padding: 0 0 0 .75rem; border: 0; background: transparent; color: var(--muted); cursor: pointer; font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; }
  .menu-button i, .menu-button i::before, .menu-button i::after { display: block; width: 1.3rem; height: 1px; background: currentColor; transition: transform .18s, opacity .18s; }
  .menu-button i { position: relative; }
  .menu-button i::before, .menu-button i::after { position: absolute; content: ""; left: 0; }
  .menu-button i::before { transform: translateY(-.42rem); }
  .menu-button i::after { transform: translateY(.42rem); }
  header[data-open] .menu-button i { background: transparent; }
  header[data-open] .menu-button i::before { transform: rotate(45deg); }
  header[data-open] .menu-button i::after { transform: rotate(-45deg); }
  @media (max-width: 820px) {
    header { gap: .75rem; }
    .menu-button { display: inline-flex; }
    nav {
      position: absolute;
      inset: calc(100% + .75rem) 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      min-width: 0;
      padding: .55rem 0;
      max-height: calc(100svh - var(--header) - 1.5rem);
      overflow-y: auto;
      border: 1px solid #30383c;
      background: #171d20;
      box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, .26);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-.35rem);
      visibility: hidden;
      transition: opacity .16s, transform .16s, visibility .16s;
    }
    header[data-open] nav { opacity: 1; pointer-events: auto; transform: translateY(0); visibility: visible; }
    nav a { display: flex; align-items: center; min-height: 3.1rem; padding: 0 1rem; border-bottom: 1px solid #30383c; color: var(--ink); font-size: .9rem; }
    nav a:last-child { border-bottom: 0; }
    .locale { padding-left: 1rem; border-left: 0; color: var(--muted); font-size: .75rem; }
  }
  @media (max-width: 420px) {
    header { width: calc(100% - 2rem); }
    .menu-button span { font-size: .66rem; }
  }
</style>
