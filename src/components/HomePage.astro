---
import { artifacts } from "../data/releases";
import { getCopy } from "../lib/i18n";
import { site, type Locale } from "../data/site";

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getCopy(locale);
const base = `/${locale}`;
const en = locale === "en";
---
<section class="hero wrap">
  <div class="hero-copy">
    <p class="status"><span>Alpha</span> v{site.version}</p>
    <h1>Lumière</h1>
    <p class="tagline">{en ? "A French-first programming language." : "Un langage de programmation pensé en français."}</p>
    <p class="lede">{en ? "Lumière runs .lum programs written with French syntax, with a command line for execution, inspection, testing, and an interactive shell." : "Lumière exécute des programmes .lum écrits avec une syntaxe française, avec une ligne de commande pour exécuter, inspecter, tester et ouvrir un shell interactif."}</p>
    <div class="actions"><a class="button primary" href={`${base}/download/`}>{t.hero.primary}</a><a class="button" href={`${base}/learn/`}>{en ? "Start learning" : "Commencer"}</a></div>
  </div>
  <div class="example" aria-label={en ? "Lumière code example" : "Exemple de code Lumière"}>
    <div class="file"><span>bonjour.lum</span><span>01–07</span></div>
    <pre><code><i>fonction</i> principal() &#123;
  afficher("Bonjour, monde!")
&#125;</code></pre>
    <div class="result"><span>sortie</span><code>Bonjour, monde!</code></div>
  </div>
</section>

<section class="summary section wrap">
  <div><p class="eyebrow">{en ? "Available today" : "Disponible aujourd’hui"}</p><h2>{en ? "An alpha you can actually run." : "Une alpha que vous pouvez vraiment exécuter."}</h2></div>
  <div class="facts">
    <div><strong>VM</strong><span>{en ? "default backend" : "backend par défaut"}</span></div>
    <div><strong>04</strong><span>{en ? "release artifacts" : "artefacts de version"}</span></div>
    <div><strong>CLI</strong><span>{en ? "run, test, inspect" : "exécuter, tester, inspecter"}</span></div>
  </div>
  <p class="summary-copy">{en ? "The current alpha includes functions, typed declarations, modules, classes, interfaces, collections, control flow, and runtime diagnostics. Libraries, tooling, and some APIs may still change between releases." : "L’alpha actuelle inclut fonctions, déclarations typées, modules, classes, interfaces, collections, contrôle de flux et diagnostics d’exécution. Les bibliothèques, les outils et certaines API peuvent encore évoluer entre les versions."}</p>
</section>

<section class="install section wrap">
  <div class="section-heading"><p class="eyebrow">{t.release.eyebrow}</p><h2>{en ? "Install Lumière." : "Installer Lumière."}</h2><p>{t.release.body}</p></div>
  <div class="install-options">
    <div class="command"><code>curl -fsSL https://raw.githubusercontent.com/SY-Technologies/lumiere/main/scripts/install.sh | sh</code><button aria-label="Copy installation command" data-copy>{en ? "Copy" : "Copier"}</button></div>
    <div class="platforms">{artifacts.map((artifact) => <a href={artifact.href}><span><strong>{artifact.label}</strong><small>{artifact.detail}</small></span><span>{artifact.format} ↓</span></a>)}</div>
    <a class="source" href={`${site.repository}#build`}>{en ? "Build from source with CMake and C++20" : "Compiler les sources avec CMake et C++20"} <span>↗</span></a>
  </div>
</section>

<section class="architecture section wrap">
  <div class="section-heading"><p class="eyebrow">Architecture</p><h2>{en ? "Understand the current implementation." : "Comprendre l’implémentation actuelle."}</h2><p>{en ? "Follow the documented path from source files to the VM, the tree-walker, built-in modules, and LumiTest." : "Suivez le parcours documenté des fichiers source vers la VM, l’interpréteur tree-walk, les modules intégrés et LumiTest."}</p><a href={`${base}/architecture/`}>{en ? "Read the architecture notes" : "Lire les notes d’architecture"} →</a></div>
  <ol class="pipeline"><li><span>01</span><strong>{en ? "Parse" : "Parser"}</strong></li><li><span>02</span><strong>{en ? "Run on VM" : "Exécuter sur VM"}</strong></li><li><span>03</span><strong>{en ? "Use shell" : "Utiliser le shell"}</strong></li><li><span>04</span><strong>{en ? "Run LumiTest" : "Lancer LumiTest"}</strong></li><li><span>05</span><strong>{en ? "Inspect IR" : "Inspecter l’IR"}</strong></li></ol>
</section>

<section class="journal section wrap">
  <div><p class="eyebrow">{en ? "Engineering journal" : "Journal d’ingénierie"}</p><h2>{en ? "The reasoning behind the language." : "Le raisonnement derrière le langage."}</h2></div>
  <a href={`${base}/journal/`}><span>{en ? "No articles yet" : "Aucun article"}</span><strong>{en ? "The journal will open when the first article is published." : "Le journal ouvrira lorsque le premier article sera publié."}</strong><small>{en ? "Current documentation lives in Learn, Architecture, and Download." : "La documentation actuelle se trouve dans Apprendre, Architecture et Télécharger."}</small><i>→</i></a>
</section>

<footer class="wrap"><span>© 2026 Axiomatik</span><span>Lumière {site.version} · Alpha</span><a href={site.repository}>GitHub ↗</a></footer>

<script>
  const button = document.querySelector<HTMLButtonElement>("[data-copy]");
  button?.addEventListener("click", async () => {
    await navigator.clipboard.writeText("curl -fsSL https://raw.githubusercontent.com/SY-Technologies/lumiere/main/scripts/install.sh | sh");
    button.textContent = document.documentElement.lang === "fr" ? "Copié" : "Copied";
  });
</script>

<style>
  .wrap { width: min(100% - 2 * var(--gutter), var(--page)); margin-inline: auto; }
  .hero { width: 100%; margin-inline: 0; display: grid; grid-template-columns: minmax(0, .9fr) minmax(24rem, 1.1fr); gap: clamp(3rem, 8vw, 7rem); align-items: center; min-height: calc(100svh - var(--header)); padding: clamp(5rem, 9vw, 7rem) max(var(--gutter), calc((100% - var(--page)) / 2)) clamp(6rem, 11vw, 9rem); background: var(--prussian); border-bottom: 1px solid #304855; }
  .hero-copy { position: relative; min-width: 0; max-width: 35rem; padding-left: 1.5rem; }
  .hero-copy::before { position: absolute; content: ""; inset: .25rem auto .2rem 0; width: 2px; background: var(--accent); }
  .status { margin: 0 0 1.4rem; color: #8999a2; font: .67rem var(--font-mono); }.status span { color: #f08a72; }
  h1, h2 { margin: 0; color: var(--ink); font-family: var(--font-body); font-weight: 500; letter-spacing: -.045em; }
  h1 { font-size: clamp(4.5rem, 8vw, 7rem); line-height: .95; }
  h2 { max-width: 43rem; font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.08; }
  .tagline { max-width: 34rem; margin: 1.8rem 0 1rem; color: #d4d7da; font-size: clamp(1.15rem, 2vw, 1.5rem); line-height: 1.45; letter-spacing: -.02em; }
  .lede, .section-heading > p:not(.eyebrow), .summary-copy { color: var(--muted); }
  .hero .lede { color: #aebbc1; }
  .actions { display: flex; gap: .75rem; margin-top: 2rem; }
  .example { position: relative; z-index: 2; min-width: 0; max-width: 100%; border: 1px solid #3a505c; background: var(--prussian-deep); box-shadow: 0 1.5rem 4rem rgba(5,12,16,.22); transform: translateY(1.5rem); }
  .file, .result { display: flex; justify-content: space-between; padding: .9rem 1.1rem; color: #718893; font: .62rem var(--font-mono); text-transform: uppercase; letter-spacing: .08em; }
  .file { border-bottom: 1px solid #30434d; }.result { justify-content: flex-start; gap: 3rem; border-top: 1px solid #30434d; }.result code { color: var(--ink); text-transform: none; }
  pre { max-width: 100%; margin: 0; padding: clamp(1.5rem, 4vw, 3.5rem); overflow-x: auto; color: #d8dee1; font: clamp(.78rem, 1.2vw, .9rem)/2 var(--font-mono); } pre i { color: #ef8a73; font-style: normal; }
  .section { width: 100%; margin-inline: 0; padding: clamp(5.5rem, 10vw, 8rem) max(var(--gutter), calc((100% - var(--page)) / 2)); border-top: 1px solid var(--line); }
  .summary { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem 7rem; background: #171d20; border-color: #30383c; }
  .summary > *, .install > *, .architecture > *, .journal > * { min-width: 0; }
  .summary h2 { color: var(--ink); }.summary .eyebrow, .summary .facts span { color: var(--faint); }.summary .summary-copy { color: var(--muted); }.summary .facts div { border-color: #30383c; }
  .facts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; align-self: end; }.facts div { display: flex; flex-direction: column; border-left: 1px solid var(--line); padding-left: 1rem; }.facts strong { font: 1.4rem var(--font-mono); }.facts span { color: var(--faint); font-size: .7rem; }
  .summary-copy { grid-column: 2; max-width: 38rem; margin: 0; }
  .install, .architecture { display: grid; grid-template-columns: .75fr 1.25fr; gap: clamp(4rem, 10vw, 9rem); }.section-heading { max-width: 32rem; }.section-heading a { display: inline-block; margin-top: 1rem; color: inherit; font-size: .78rem; text-decoration: none; }
  .install { background: #14191c; border-color: #30383c; }.install h2 { color: var(--ink); }.install .eyebrow { color: var(--faint); }.install .section-heading > p:not(.eyebrow) { color: var(--muted); }
  .command { display: flex; min-width: 0; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 2rem; padding: 1rem; border: 1px solid #30383c; background: #171d20; font: .68rem var(--font-mono); }.command code { min-width: 0; max-width: 100%; overflow: hidden; color: #d8dee1; text-overflow: ellipsis; white-space: nowrap; }.command button { flex: 0 0 auto; color: #df846f; background: none; border: 0; cursor: pointer; font: inherit; }
  .platforms { display: grid; grid-template-columns: 1fr 1fr; border-top: 1px solid #30383c; }.platforms a { display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid #30383c; text-decoration: none; }.platforms a:nth-child(odd) { padding-right: 1.5rem; }.platforms a:nth-child(even) { padding-left: 1.5rem; border-left: 1px solid #30383c; }.platforms strong { font-size: .85rem; }.platforms small { display: block; color: var(--muted); font-size: .68rem; }.platforms a > span:last-child { color: var(--muted); font: .65rem var(--font-mono); }
  .source { display: flex; justify-content: space-between; gap: 1rem; margin-top: 1.4rem; color: var(--muted); font-size: .75rem; text-decoration: none; }
  .architecture { background: var(--prussian-deep); border-color: #293c47; }
  .pipeline { list-style: none; margin: 1rem 0 0; padding: 0; border-top: 1px solid var(--line); }.pipeline li { display: grid; grid-template-columns: 3rem 1fr; padding: 1.1rem 0; border-bottom: 1px solid var(--line); }.pipeline span { color: var(--faint); font: .62rem var(--font-mono); }.pipeline strong { font-size: .9rem; font-weight: 500; }
  .journal { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; background: #202427; }.journal a { position: relative; display: flex; min-width: 0; flex-direction: column; justify-content: center; padding: 1.5rem 3rem 1.5rem 0; border-top: 1px solid #3a3f43; border-bottom: 1px solid #3a3f43; text-decoration: none; transition: padding-left .18s; }.journal a:hover { padding-left: .75rem; }.journal a span, .journal a small { color: var(--faint); font-size: .67rem; }.journal a strong { margin: .5rem 0; font-weight: 500; }.journal a i { position: absolute; right: .5rem; font-style: normal; }
  footer { display: flex; justify-content: space-between; padding-block: 2rem; border-top: 1px solid var(--line); color: var(--faint); font-size: .67rem; } footer a { color: var(--muted); text-decoration: none; }
  @media (max-width: 900px) { .hero, .summary, .install, .architecture, .journal { grid-template-columns: 1fr; }.hero { min-height: auto; padding-top: clamp(3.5rem, 9vw, 5rem); padding-bottom: clamp(4rem, 10vw, 6rem); }.example { max-width: 42rem; transform: none; }.summary-copy { grid-column: 1; }.section { gap: 3rem; } }
  @media (max-width: 700px) { .hero, .section { padding-inline: var(--gutter); } h2 { font-size: clamp(1.85rem, 9vw, 2.45rem); }.summary, .install, .architecture, .journal { gap: 2.5rem; }.facts { gap: .75rem; }.facts div { min-width: 0; }.platforms a { gap: 1rem; }.platforms a > span:first-child { min-width: 0; }.platforms strong, .platforms small { overflow-wrap: anywhere; }.source { align-items: flex-start; flex-wrap: wrap; } }
  @media (max-width: 620px) { h1 { font-size: clamp(3.2rem, 17vw, 4.5rem); }.hero-copy { max-width: none; padding-left: 1rem; }.tagline { margin-top: 1.25rem; }.section { padding-block: clamp(4rem, 14vw, 5.5rem); }.command { align-items: stretch; flex-direction: column; }.command code { display: block; overflow-x: auto; text-overflow: clip; white-space: nowrap; -webkit-overflow-scrolling: touch; }.command button { align-self: flex-start; padding: .2rem 0; }.journal a { padding-right: 2rem; } }
  @media (max-width: 520px) { .actions { align-items: stretch; flex-direction: column; }.platforms { grid-template-columns: 1fr; }.platforms a:nth-child(n) { padding-inline: 0; border-left: 0; }.facts { grid-template-columns: 1fr; }.facts div { border-left: 0; border-top: 1px solid #30383c; padding: .9rem 0 0; }.file, .result { gap: 1rem; padding-inline: .85rem; }.result { align-items: flex-start; flex-direction: column; }.example { box-shadow: 0 1rem 2rem rgba(5,12,16,.18); } pre { padding: 1.1rem; font-size: .74rem; line-height: 1.85; }.pipeline li { grid-template-columns: 2.25rem 1fr; }.journal a { padding-right: 1.5rem; }.journal a i { right: 0; } footer { flex-direction: column; gap: .5rem; } }
  @media (max-width: 380px) { h1 { font-size: clamp(2.75rem, 16vw, 3.2rem); }.hero-copy::before { display: none; }.hero-copy { padding-left: 0; }.journal a { padding-right: 0; }.journal a i { position: static; margin-top: .75rem; } }
</style>
